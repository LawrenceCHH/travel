---
---
{
  "name": "{{ site.title | escape }}",
  "short_name": "{{ site.title | escape | truncate: 12, '' }}",
  "description": "{{ site.description | escape }}",
  "start_url": "{{ "/" | relative_url }}",
  "scope": "{{ "/" | relative_url }}",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#0085a1",
  "icons": [
    {
      "src": "{{ "/img/icons/icon-192.png" | relative_url }}",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "{{ "/img/icons/icon-512.png" | relative_url }}",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "{{ "/img/icons/icon.svg" | relative_url }}",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ]
}
